{
  "manifest_version": 3,

  "name": "SignalCheck",

  "version": "0.2.1",

  "description": "Enterprise contextual analysis engine. Detects structural trust and rhetorical manipulation signals. Does not determine truth or falsity.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "SignalCheck — Enterprise Contextual Analysis"
  },

  "background": {
    "service_worker": "service_worker.js"
  },

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://gesignalcheck-production-8e78.up.railway.app/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}