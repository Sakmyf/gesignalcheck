# ======================================================
# SIGNALCHECK / CANDADO — ENV CONFIG
# ======================================================

# ------------------------------------------------------
# ENVIRONMENT
# ------------------------------------------------------
ENV_MODE=development
# production | development

# ------------------------------------------------------
# SECURITY — JWT
# ------------------------------------------------------
JWT_PRIVATE_PEM=
JWT_PUBLIC_PEM=
JWT_KID=key-2026-01

# ------------------------------------------------------
# DATABASE
# ------------------------------------------------------
DATABASE_URL=

# Railway lo inyecta solo, pero lo dejamos por claridad

# ------------------------------------------------------
# CORS
# ------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://TU_EXTENSION_ID

# ------------------------------------------------------
# RATE LIMIT
# ------------------------------------------------------
RATE_LIMIT_RPS=10

# ------------------------------------------------------
# AI KEYS (FUTURO)
# ------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ------------------------------------------------------
# MODEL / ML
# ------------------------------------------------------
MODEL_PATH=modelos/candado_brain_v1.pkl