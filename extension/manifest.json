{
  "manifest_version": 3,
  "name": "SignalCheck",
  "version": "0.3.0",
  "description": "Análisis estructural del contenido — SignalCheck Engine",

  "action": {
    "default_popup": "popup.html",
    "default_title": "SignalCheck"
  },

  "background": {
    "service_worker": "service_worker.js"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://gesignalcheck-production-8e78.up.railway.app/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}